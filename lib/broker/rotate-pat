#!/usr/bin/env bash
# /usr/local/sbin/rotate-pat — broker GitHub credential rotation. Root-owned, mode 700.
#
# In the default PAT mode, reads a new GitHub fine-grained PAT from stdin,
# atomically replaces the broker token file, and restarts the broker.
# In GitHub App mode, reads the App private key PEM from stdin and stores it
# alongside an EnvironmentFile containing the App and installation ids.
# The agent is never involved.
#
# Usage:
#   sudo -p "[sudo] VPS Linux password for $USER: " rotate-pat <<<'github_pat_NEW_TOKEN_HERE'
# Or interactively:
#   sudo -p "[sudo] VPS Linux password for $USER: " env FIELDWORK_ROTATE_PAT_TTY=1 rotate-pat
#   paste the token when prompted; input is hidden

set -euo pipefail

# Validate a PAT against the forge API before we ever store it, so a typo'd,
# expired, revoked, or wrong-repo token cannot replace a working one and restart
# the broker with a dead credential. Side-effect-free; the caller decides what to
# do with the exit code:
#   0  token is live (and, if a repo was named, reachable with write access)
#   1  GitHub definitively rejected it -> abort, keep the existing token
#   2  could not reach the API at all  -> warn and proceed (don't brick setup on
#      a network/outage when we cannot prove the token is bad)
# Fine-grained PATs do not expose their granted permissions via any API, so this
# checks liveness always and, when FIELDWORK_PAT_PROBE_REPO is set, repo
# reachability plus the `permissions.push` write proxy. GitHub.com only.
fieldwork_token_http() {
  local token="$1"
  local url="$2"
  local forge="$3"
  local ca="${4:-}"
  printf '%s' "$token" | FIELDWORK_HTTP_FORGE="$forge" FIELDWORK_HTTP_CA="$ca" python3 -c '
import json, os, ssl, sys, urllib.error, urllib.request

token = sys.stdin.read().rstrip("\n")
url = sys.argv[1]
forge = os.environ.get("FIELDWORK_HTTP_FORGE", "github")
headers = {"Accept": "application/json"}
if forge == "gitlab":
    headers["PRIVATE-TOKEN"] = token
else:
    headers["Authorization"] = f"Bearer {token}"
    headers["Accept"] = "application/vnd.github+json"
    headers["X-GitHub-Api-Version"] = "2022-11-28"
context = ssl.create_default_context(cafile=os.environ.get("FIELDWORK_HTTP_CA") or None)
opener = urllib.request.build_opener(urllib.request.ProxyHandler({}), urllib.request.HTTPSHandler(context=context))
req = urllib.request.Request(url, headers=headers)
try:
    with opener.open(req, timeout=10) as resp:
        body = resp.read().decode("utf-8", "replace")
        print(body)
        print(resp.getcode())
except urllib.error.HTTPError as exc:
    body = exc.read().decode("utf-8", "replace")
    print(body)
    print(exc.code)
except Exception:
    print("")
    print("000")
' "$url"
}

fieldwork_validate_pat() {
  local token="$1"
  local forge="${FIELDWORK_FORGE:-github}"
  case "$forge" in
    github|"") forge="github" ;;
    gitlab) ;;
    *) echo "[rotate-pat] unsupported FIELDWORK_FORGE: $forge" >&2; return 1 ;;
  esac

  if [ "$forge" = "gitlab" ]; then
    local api="${FIELDWORK_GITLAB_API:-https://gitlab.com/api/v4}"
    local ca="${FIELDWORK_GITLAB_CA_BUNDLE:-}"
    local resp code
    resp="$(fieldwork_token_http "$token" "$api/user" gitlab "$ca")" || resp=$'\n000'
    code="${resp##*$'\n'}"
    case "$code" in
      200) return 0 ;;
      401|403) echo "[rotate-pat] GitLab rejected the token (HTTP $code): expired, revoked, missing api/write_repository, or insufficient role." >&2; return 1 ;;
      000) echo "[rotate-pat] could not reach $api (network or TLS)." >&2; return 2 ;;
      *) echo "[rotate-pat] unexpected response from $api/user (HTTP $code); could not validate." >&2; return 2 ;;
    esac
  fi

  local api="${FIELDWORK_GITHUB_API:-https://api.github.com}"

  local resp code
  resp="$(fieldwork_token_http "$token" "$api/rate_limit" github)" || resp=$'\n000'
  code="${resp##*$'\n'}"
  case "$code" in
    200) ;;
    401|403) echo "[rotate-pat] GitHub rejected the token (HTTP $code): expired, revoked, or mistyped." >&2; return 1 ;;
    000) echo "[rotate-pat] could not reach $api (network)." >&2; return 2 ;;
    *) echo "[rotate-pat] unexpected response from $api (HTTP $code); could not validate." >&2; return 2 ;;
  esac

  local repo="${FIELDWORK_PAT_PROBE_REPO:-}"
  [ -n "$repo" ] || return 0

  local rcode body
  resp="$(fieldwork_token_http "$token" "$api/repos/$repo" github)" || { echo "[rotate-pat] could not reach $api for the $repo check." >&2; return 2; }
  rcode="${resp##*$'\n'}"
  body="${resp%$'\n'*}"
  case "$rcode" in
    200) ;;
    404) echo "[rotate-pat] the token cannot see $repo (HTTP 404): add it to the PAT's selected repositories." >&2; return 1 ;;
    403) echo "[rotate-pat] the token lacks access to $repo (HTTP 403): grant Metadata: Read." >&2; return 1 ;;
    000) echo "[rotate-pat] could not reach $api for the $repo check." >&2; return 2 ;;
    *) echo "[rotate-pat] unexpected response for $repo (HTTP $rcode); could not validate." >&2; return 2 ;;
  esac
  if printf '%s' "$body" | grep -q '"push"[[:space:]]*:[[:space:]]*true'; then
    return 0
  fi
  echo "[rotate-pat] the token can read $repo but lacks write access (Contents: Read and write required)." >&2
  return 1
}

fieldwork_validate_github_app_ids() {
  local app_id="$1"
  local installation_id="$2"
  case "$app_id" in ""|*[!0-9]*) echo "GitHub App id must be numeric" >&2; return 1 ;; esac
  case "$installation_id" in ""|*[!0-9]*) echo "GitHub App installation id must be numeric" >&2; return 1 ;; esac
  return 0
}

if [ "${FIELDWORK_ROTATE_PAT_SOURCE_ONLY:-0}" = "1" ]; then
  return 0 2>/dev/null || exit 0
fi

[ "$(id -u)" -eq 0 ] || { echo "must run as root" >&2; exit 1; }

# Identities and paths default to the neutral Fieldwork layout but can be
# overridden to match a non-default broker install.
BROKER_USER="${FIELDWORK_BROKER_USER:-fieldwork-pr-broker}"
BROKER_SERVICE="${FIELDWORK_BROKER_SERVICE:-fieldwork-pr-broker}"
AGENT_USER="${FIELDWORK_REMOTE_USER:-fieldwork}"
FORGE="${FIELDWORK_FORGE:-github}"
CREDENTIAL_MODE="${FIELDWORK_GITHUB_CREDENTIAL_MODE:-pat}"
TOKEN_PATH="${FIELDWORK_BROKER_TOKEN_PATH:-/etc/fieldwork-pr-broker/gh-token}"
TOKEN_DIR="$(dirname "$TOKEN_PATH")"
CONFIG_DIR="${FIELDWORK_BROKER_CONFIG_DIR:-/etc/fieldwork-pr-broker}"
APP_PRIVATE_KEY_PATH="${FIELDWORK_GITHUB_APP_PRIVATE_KEY_PATH:-$CONFIG_DIR/github-app-private-key.pem}"
APP_ENV_PATH="${FIELDWORK_GITHUB_APP_ENV_PATH:-$CONFIG_DIR/credential.env}"

case "$FORGE" in
  github|"") FORGE="github" ;;
  gitlab) CREDENTIAL_MODE="pat" ;;
  *) echo "unsupported FIELDWORK_FORGE: $FORGE" >&2; exit 1 ;;
esac

case "$CREDENTIAL_MODE" in
  pat|"") CREDENTIAL_MODE="pat" ;;
  app) ;;
  *) echo "unsupported FIELDWORK_GITHUB_CREDENTIAL_MODE: $CREDENTIAL_MODE" >&2; exit 1 ;;
esac

TOKEN=""
TTY_STATE=""
restore_tty() {
  if [ -n "$TTY_STATE" ]; then
    stty "$TTY_STATE" </dev/tty 2>/dev/null || stty "$TTY_STATE" 2>/dev/null || true
    TTY_STATE=""
  fi
}
trap 'restore_tty' EXIT

mark_agent_credential_confirmed() {
  local marker="$1"
  if id "$AGENT_USER" >/dev/null 2>&1; then
    local agent_home
    agent_home="$(getent passwd "$AGENT_USER" | cut -d: -f6)"
    if [ -n "$agent_home" ]; then
      install -d -o "$AGENT_USER" -g "$AGENT_USER" -m 700 "$agent_home/.fieldwork/state"
      : > "$agent_home/.fieldwork/state/$marker"
      chown "$AGENT_USER:$AGENT_USER" "$agent_home/.fieldwork/state/$marker"
      chmod 600 "$agent_home/.fieldwork/state/$marker"
    fi
  fi
}

write_credential_env() {
  local mode="$1"
  local tmp
  tmp="$(mktemp "$CONFIG_DIR/.credential.env.XXXXXX")"
  {
    printf 'FIELDWORK_FORGE=%s\n' "$FORGE"
    printf 'FIELDWORK_GITHUB_CREDENTIAL_MODE=%s\n' "$mode"
    if [ "$FORGE" = "gitlab" ]; then
      printf 'FIELDWORK_GITLAB_API=%s\n' "${FIELDWORK_GITLAB_API:-https://gitlab.com/api/v4}"
      if [ -n "${FIELDWORK_GITLAB_CA_BUNDLE:-}" ]; then
        printf 'FIELDWORK_GITLAB_CA_BUNDLE=%s\n' "$FIELDWORK_GITLAB_CA_BUNDLE"
      fi
    fi
    if [ "$mode" = "app" ]; then
      printf 'FIELDWORK_GITHUB_APP_ID=%s\n' "$FIELDWORK_GITHUB_APP_ID"
      printf 'FIELDWORK_GITHUB_APP_INSTALLATION_ID=%s\n' "$FIELDWORK_GITHUB_APP_INSTALLATION_ID"
      printf 'FIELDWORK_GITHUB_APP_PRIVATE_KEY_PATH=%s\n' "$APP_PRIVATE_KEY_PATH"
    fi
  } > "$tmp"
  chown root:root "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$APP_ENV_PATH"
}

store_github_app_credentials() {
  FIELDWORK_GITHUB_APP_ID="${FIELDWORK_GITHUB_APP_ID:-}"
  FIELDWORK_GITHUB_APP_INSTALLATION_ID="${FIELDWORK_GITHUB_APP_INSTALLATION_ID:-}"
  if [ -t 0 ]; then
    if [ -z "$FIELDWORK_GITHUB_APP_ID" ]; then
      printf 'GitHub App ID: ' >&2
      IFS= read -r FIELDWORK_GITHUB_APP_ID
    fi
    if [ -z "$FIELDWORK_GITHUB_APP_INSTALLATION_ID" ]; then
      printf 'GitHub App installation ID: ' >&2
      IFS= read -r FIELDWORK_GITHUB_APP_INSTALLATION_ID
    fi
    printf 'Paste GitHub App private key PEM, then press Ctrl-D:\n' >&2
  elif [ "${FIELDWORK_ROTATE_PAT_TTY:-0}" = "1" ] && [ -r /dev/tty ] && [ -w /dev/tty ]; then
    if [ -z "$FIELDWORK_GITHUB_APP_ID" ]; then
      printf 'GitHub App ID: ' >/dev/tty
      IFS= read -r FIELDWORK_GITHUB_APP_ID </dev/tty
    fi
    if [ -z "$FIELDWORK_GITHUB_APP_INSTALLATION_ID" ]; then
      printf 'GitHub App installation ID: ' >/dev/tty
      IFS= read -r FIELDWORK_GITHUB_APP_INSTALLATION_ID </dev/tty
    fi
    printf 'Paste GitHub App private key PEM, then press Ctrl-D:\n' >/dev/tty
    TOKEN="$(cat </dev/tty)"
  fi
  if [ -z "${TOKEN:-}" ]; then
    TOKEN="$(cat)"
  fi
  TOKEN="${TOKEN%$'\n'}"

  fieldwork_validate_github_app_ids "$FIELDWORK_GITHUB_APP_ID" "$FIELDWORK_GITHUB_APP_INSTALLATION_ID"
  case "$TOKEN" in
    *"BEGIN "*"PRIVATE KEY"*"END "*"PRIVATE KEY"*) ;;
    *) echo "input does not look like a GitHub App private key PEM" >&2; exit 1 ;;
  esac

  install -o "$BROKER_USER" -g "$BROKER_USER" -m 700 -d "$CONFIG_DIR"
  local tmp
  tmp="$(mktemp "$CONFIG_DIR/.github-app-private-key.XXXXXX")"
  trap 'rm -f "$tmp"' EXIT
  printf '%s\n' "$TOKEN" > "$tmp"
  chown "$BROKER_USER:$BROKER_USER" "$tmp"
  chmod 600 "$tmp"
  mv -f "$tmp" "$APP_PRIVATE_KEY_PATH"
  trap - EXIT

  write_credential_env app
  systemctl restart "$BROKER_SERVICE"
  mark_agent_credential_confirmed "broker-app-confirmed"
  echo "[rotate-pat] GitHub App credentials stored; broker restarted"
}

if [ "$CREDENTIAL_MODE" = "app" ]; then
  store_github_app_credentials
  exit 0
fi

if [ -t 0 ]; then
  TTY_STATE="$(stty -g)"
  if [ "$FORGE" = "gitlab" ]; then
    printf 'Paste GitLab token (input hidden), then press Enter: ' >&2
  else
    printf 'Paste GitHub PAT (input hidden), then press Enter: ' >&2
  fi
  stty -echo
  IFS= read -r TOKEN || true
  restore_tty
  printf '\n' >&2
elif [ "${FIELDWORK_ROTATE_PAT_TTY:-0}" = "1" ] && [ -r /dev/tty ] && [ -w /dev/tty ]; then
  TTY_STATE="$(stty -g </dev/tty)"
  if [ "$FORGE" = "gitlab" ]; then
    printf 'Paste GitLab token (input hidden), then press Enter: ' >/dev/tty
  else
    printf 'Paste GitHub PAT (input hidden), then press Enter: ' >/dev/tty
  fi
  stty -echo </dev/tty
  IFS= read -r TOKEN </dev/tty || true
  restore_tty
  printf '\n' >/dev/tty
else
  TOKEN="$(cat)"
  TOKEN="${TOKEN%$'\n'}"  # strip trailing newline only
fi

[ -n "$TOKEN" ] || { echo "empty token on stdin" >&2; exit 1; }

if [ "$FORGE" = "github" ]; then
  # Sanity-check shape (fine-grained PATs start with github_pat_).
  case "$TOKEN" in
    github_pat_*|ghp_*) ;;
    *) echo "token doesn't look like a GitHub PAT (expected github_pat_… or ghp_…)" >&2; exit 1;;
  esac
fi

set +e
fieldwork_validate_pat "$TOKEN"
pat_valid=$?
set -e
case "$pat_valid" in
  0) ;;
  2) echo "[rotate-pat] warning: could not validate the token (API unreachable); storing it anyway." >&2 ;;
  *) echo "[rotate-pat] token validation failed; keeping the existing token unchanged." >&2; exit 1 ;;
esac

DEST="$TOKEN_PATH"
TMP="$(mktemp "$TOKEN_DIR/.gh-token.XXXXXX")"
trap 'rm -f "$TMP"' EXIT

printf '%s\n' "$TOKEN" > "$TMP"
chown "$BROKER_USER:$BROKER_USER" "$TMP"
chmod 600 "$TMP"
mv -f "$TMP" "$DEST"
trap - EXIT

write_credential_env pat
systemctl restart "$BROKER_SERVICE"
mark_agent_credential_confirmed "broker-pat-confirmed"
echo "[rotate-pat] token replaced; broker restarted"
