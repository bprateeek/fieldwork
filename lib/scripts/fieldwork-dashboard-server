      .sidebar { display: none; }
    }
    .empty { text-align: center; color: var(--muted); padding: 60px 0; }
    .empty-sm { color: var(--faint); font-size: 12.5px; padding: 8px 4px; }
    .pill { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 620; line-height: 1.5; padding: 2px 9px; border-radius: 999px; border: 1px solid transparent; white-space: nowrap; }
    .pill.default { background: rgba(255,255,255,.08); color: var(--muted); }
    .pill.branch { font-family: var(--mono); font-weight: 500; letter-spacing: -0.01em; background: rgba(255,255,255,.05); color: var(--muted); border-color: var(--line-2); }
    .pill.audit { background: rgba(139,92,255,.18); color: #b69bff; }
    .pill.merged { background: rgba(163,113,247,.18); color: #c4a4ff; }
    .pill.open { background: rgba(63,185,80,.16); color: #6ed98a; }
    .pill.closed { background: rgba(248,81,73,.16); color: #ff8079; }
    .pill.info { background: rgba(91,134,255,.16); color: #8fb0ff; }
    .pill.warn { background: rgba(227,179,65,.16); color: #f0cf76; }
  </style>
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <div class="brand"><span class="brand-mark">F</span><span class="brand-name">Fieldwork</span></div>
      <nav id="nav" class="nav"></nav>
      <div class="side-card">
        <div class="side-card-title">Read-only view</div>
        <div class="side-card-text">Served over an SSH tunnel from your VPS. No write access from here.</div>
      </div>
      <div class="side-foot"><span class="dot"></span><span id="generated">Connecting\\u2026</span></div>
    </aside>
    <main class="content">
      <div class="topbar">
        <div class="greeting">
          <h1>Repository status</h1>
          <p class="sub">Live view of your Fieldwork sessions.</p>
        </div>
        <div class="top-actions"><button id="refresh" type="button">Refresh</button></div>
      </div>
      <div id="summary" class="summary"></div>
      <div class="layout">
        <div id="repos" class="main-col"></div>
        <aside class="rail">
          <div class="rail-head">Recent activity</div>
          <div id="activity" class="activity"></div>
        </aside>
      </div>
    </main>
  </div>
  <script>
    const elRefresh = document.getElementById("refresh");
    const elGenerated = document.getElementById("generated");
    const elNav = document.getElementById("nav");
    const elSummary = document.getElementById("summary");
    const elRepos = document.getElementById("repos");
    const elActivity = document.getElementById("activity");

    function node(tag, className, text) {
      const el = document.createElement(tag);
      if (className) el.className = className;
      if (text !== undefined && text !== null) el.textContent = text;
      return el;
    }

    function pill(text, kind) {
      return node("span", "pill " + (kind || "default"), text);
    }

    function safeLink(text, url) {
      if (typeof url === "string" && /^https?:\\/\\//i.test(url)) {
        const a = node("a", "link", text);
        a.href = url;
        a.target = "_blank";
        a.rel = "noopener noreferrer";
        return a;
      }
      return node("span", "mono", url || "");
    }

    function section(title, count) {
      const s = node("section", "sec");
      const h = node("div", "sec-head");
      h.append(node("h3", "sec-title", title));
      if (count !== undefined) h.append(node("span", "sec-count", String(count)));
      s.append(h);
      return s;
    }

    function prKind(state) {
      const s = String(state || "").toUpperCase();
      if (s === "MERGED") return "merged";
      if (s === "CLOSED") return "closed";
      if (s === "OPEN" || s === "") return "open";
      return "default";
    }

    function statCard(label, value, sub, kind) {
      const c = node("div", "stat " + kind);
      const top = node("div", "stat-top");
      top.append(node("div", "stat-label", label));
      top.append(node("div", "stat-btn", "\\u2197"));
      c.append(top);
      c.append(node("div", "stat-value", String(value)));
      c.append(node("div", "stat-sub", sub));
      return c;
    }

    function navItem(label, icon, onClick, active) {
      const b = node("button", "nav-item" + (active ? " active" : ""));
      b.type = "button";
      b.append(node("span", "nav-ico", icon));
      b.append(node("span", "nav-label", label));
      b.addEventListener("click", onClick);
      return b;
    }

    function renderRepo(repo) {
      const card = node("section", "panel");
      card.id = "repo-" + repo.slug;
      const head = node("div", "panel-head");
      head.append(node("span", "panel-name", repo.slug));
      const audit = repo.latest_audit_event || {};
      if (audit.event) head.append(pill(audit.event + (audit.branch ? (" \\u00b7 " + audit.branch) : ""), "audit"));
      card.append(head);

      const wEntries = Object.entries(repo.worktrees || {});
      const wsec = section("Worktrees", wEntries.length);
      if (wEntries.length) {
        for (const [path, wt] of wEntries) {
          const r = node("div", "wt");
          const top = node("div", "wt-top");
          top.append(pill(wt.branch || "(detached)", "branch"));
          top.append(node("span", "mono", String(wt.rev || "").slice(0, 12)));
          const ahead = Number(wt.ahead_of_base || 0);
          const pending = Number(wt.dirty_count || 0) + Number(wt.staged_count || 0) + Number(wt.untracked_count || 0);
          if (ahead) top.append(pill("\\u2191" + ahead, "info"));
          if (pending) top.append(pill("\\u25cf " + pending, "warn"));
          r.append(top);
          r.append(node("div", "wt-path mono", path));
          wsec.append(r);
        }
      } else {
        wsec.append(node("div", "empty-sm", "No active worktrees."));
      }
      card.append(wsec);

      const prEntries = Object.entries(repo.prs || {});
      if (prEntries.length) {
        const psec = section("Pull requests", prEntries.length);
        for (const [branch, pr] of prEntries) {
          const r = node("div", "pr");
          r.append(pill(String(pr.state || "OPEN").toUpperCase(), prKind(pr.state)));
          r.append(node("span", "pr-num", "#" + (pr.number || "?")));
          r.append(node("span", "pr-branch", branch));
          if (pr.url) r.append(safeLink("open \\u2197", pr.url));
          psec.append(r);
        }
        card.append(psec);
      }

      const foot = node("div", "card-foot");
      foot.append(node("span", "meta-label", "Resume context"));
      foot.append(node("span", "mono", repo.resume_context_present ? repo.resume_context_path : "missing"));
      card.append(foot);
      return card;
    }

    function activityItem(entry) {
      const it = node("div", "act");
      const top = node("div", "act-top");
      if (entry.branch) top.append(pill(entry.branch, "branch"));
      top.append(node("span", "act-repo", entry.slug));
      it.append(top);
      it.append(node("div", "act-msg", entry.msg));
      if (entry.ts) it.append(node("div", "act-ts", entry.ts));
      return it;
    }

    function collectActivity(repos) {
      const acts = [];
      for (const r of repos) {
        for (const line of (r.journal_tail || [])) {
          const parts = String(line).replace(/^-\\s*/, "").split(" | ");
          if (parts.length >= 3) {
            acts.push({ slug: r.slug, ts: parts[0], branch: parts[1], msg: parts.slice(2).join(" | ") });
          } else {
            acts.push({ slug: r.slug, ts: "", branch: "", msg: String(line) });
          }
        }
      }
      acts.sort((a, b) => String(b.ts || "").localeCompare(String(a.ts || "")));
      return acts.slice(0, 14);
    }

    async function load() {
      elRefresh.disabled = true;
      const label = elRefresh.textContent;
      elRefresh.textContent = "Refreshing\\u2026";
      try {
        const res = await fetch("/api/status", { cache: "no-store" });
        const data = await res.json();
        elGenerated.textContent = data.generated_at ? ("Updated " + data.generated_at) : "Connected";
        const repos = data.repos || [];

        let worktrees = 0, openPrs = 0, mergedPrs = 0;
        for (const r of repos) {
          worktrees += Object.keys(r.worktrees || {}).length;
          for (const pr of Object.values(r.prs || {})) {
            const st = String(pr.state || "").toUpperCase();
            if (st === "MERGED" || pr.merged_at) mergedPrs++;
            else if (st !== "CLOSED") openPrs++;
          }
        }
        elSummary.replaceChildren(
          statCard("Worktrees", worktrees, "active checkouts", "amber"),
          statCard("Open PRs", openPrs, "awaiting review", "violet"),
          statCard("Merged", mergedPrs, "shipped", "green"),
        );

        const nav = [navItem("Overview", "\\u25c9", () => window.scrollTo({ top: 0, behavior: "smooth" }), true)];
        for (const r of repos) {
          nav.push(navItem(r.slug, r.slug.slice(0, 1).toUpperCase(), () => {
            const t = document.getElementById("repo-" + r.slug);
            if (t) t.scrollIntoView({ behavior: "smooth", block: "start" });
          }, false));
        }
        elNav.replaceChildren(...nav);

        if (!repos.length) {
          elRepos.replaceChildren(node("div", "empty", "No Fieldwork repo state found yet."));
        } else {
          elRepos.replaceChildren(...repos.map(renderRepo));
        }

        const recent = collectActivity(repos);
        if (recent.length) {
          elActivity.replaceChildren(...recent.map(activityItem));
        } else {
          elActivity.replaceChildren(node("div", "empty-sm", "No recent activity."));
        }
      } catch (err) {
        elRepos.replaceChildren(node("div", "empty", String(err)));
      } finally {
        elRefresh.disabled = false;
        elRefresh.textContent = label;
      }
    }

    elRefresh.addEventListener("click", load);
    load();
  </script>
</body>
</html>
"""


def snapshot_json() -> tuple[int, bytes]:
    try:
        result = subprocess.run(
            [SNAPSHOT],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=10,
        )
        json.loads(result.stdout.decode("utf-8"))
        return 200, result.stdout
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired, json.JSONDecodeError):
        return 503, b'{"ok": false, "error": "status snapshot unavailable"}\n'


class DashboardHandler(BaseHTTPRequestHandler):
    server_version = "fieldwork-dashboard/1"

    def send_bytes(self, status: int, content_type: str, body: bytes) -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self) -> None:  # noqa: N802
        if self.path in ("/", "/index.html"):
            self.send_bytes(200, "text/html; charset=utf-8", INDEX_HTML.encode("utf-8"))
            return
        if self.path == "/api/status":
            status, body = snapshot_json()
            self.send_bytes(status, "application/json; charset=utf-8", body)
            return
        if self.path == "/healthz":
            self.send_bytes(200, "application/json; charset=utf-8", b'{"ok": true}\n')
            return
        self.send_bytes(404, "application/json; charset=utf-8", b'{"ok": false, "error": "not found"}\n')

    def method_not_allowed(self) -> None:
        self.send_bytes(405, "application/json; charset=utf-8", b'{"ok": false, "error": "GET only"}\n')

    do_HEAD = method_not_allowed  # type: ignore[assignment]
    do_POST = method_not_allowed  # type: ignore[assignment]
    do_PUT = method_not_allowed  # type: ignore[assignment]
    do_DELETE = method_not_allowed  # type: ignore[assignment]
    do_PATCH = method_not_allowed  # type: ignore[assignment]

    def log_message(self, fmt: str, *args: object) -> None:
        return


def main() -> int:
    if HOST != "127.0.0.1":
        print("fieldwork-dashboard-server binds only to 127.0.0.1", file=sys.stderr)
        return 2
    server = ThreadingHTTPServer((HOST, PORT), DashboardHandler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
