    .stat-sub { margin-top: 6px; font-size: 12.5px; font-weight: 560; opacity: .72; }
    /* Layout */
    .layout { display: grid; grid-template-columns: 1fr 320px; gap: 18px; align-items: start; }
    .main-col { display: flex; flex-direction: column; gap: 18px; }
    .panel { border: 1px solid var(--line); border-radius: 18px; background: var(--card); padding: 20px 22px; box-shadow: 0 1px 2px rgba(0,0,0,.3); }
    .panel-head { display: flex; align-items: center; gap: 11px; flex-wrap: wrap; }
    .panel-name { font-size: 16px; font-weight: 660; letter-spacing: -0.01em; }
    .sec { margin-top: 18px; }
    .sec-head { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .sec-title { margin: 0; font-size: 10.5px; font-weight: 720; text-transform: uppercase; letter-spacing: .1em; color: var(--faint); }
    .sec-count { font-size: 11px; font-weight: 580; color: var(--muted); padding: 1px 8px; border-radius: 999px; background: rgba(255,255,255,.06); }
    .mono { font-family: var(--mono); font-size: 12px; letter-spacing: -0.01em; }
    .wt { padding: 9px 10px; border-radius: 10px; transition: background .1s ease; }
    .wt:hover, .pr:hover { background: var(--hover); }
