#!/usr/bin/env python3
"""Local-only Fieldwork dashboard server."""
from __future__ import annotations

from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
import json
import os
from pathlib import Path
import subprocess
import sys


HOST = os.environ.get("FIELDWORK_DASHBOARD_HOST", "127.0.0.1")
PORT = int(os.environ.get("FIELDWORK_DASHBOARD_PORT", "8765"))
SNAPSHOT = os.environ.get(
    "FIELDWORK_DASHBOARD_SNAPSHOT",
    str(Path(__file__).with_name("fieldwork-status-snapshot")),
)


INDEX_HTML = """<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Fieldwork Dashboard</title>
  <style>
    :root { color-scheme: light dark; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
    body { margin: 0; background: Canvas; color: CanvasText; }
    header { padding: 18px 24px; border-bottom: 1px solid color-mix(in srgb, CanvasText 18%, transparent); display: flex; justify-content: space-between; gap: 16px; align-items: baseline; }
    h1 { font-size: 20px; margin: 0; font-weight: 650; letter-spacing: 0; }
    main { max-width: 1180px; margin: 0 auto; padding: 20px 24px 40px; }
    .meta { color: color-mix(in srgb, CanvasText 62%, transparent); font-size: 13px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 14px; }
    .repo { border: 1px solid color-mix(in srgb, CanvasText 18%, transparent); border-radius: 8px; padding: 14px; background: color-mix(in srgb, Canvas 96%, CanvasText 4%); }
    .repo h2 { margin: 0 0 10px; font-size: 17px; letter-spacing: 0; }
    .row { display: flex; justify-content: space-between; gap: 12px; border-top: 1px solid color-mix(in srgb, CanvasText 10%, transparent); padding: 8px 0; font-size: 13px; }
    .row:first-of-type { border-top: 0; }
    .label { color: color-mix(in srgb, CanvasText 62%, transparent); }
    .value { text-align: right; overflow-wrap: anywhere; }
    ul { margin: 8px 0 0; padding-left: 18px; }
    li { margin: 4px 0; overflow-wrap: anywhere; }
    .empty { color: color-mix(in srgb, CanvasText 62%, transparent); padding: 28px 0; }
    button { font: inherit; border: 1px solid color-mix(in srgb, CanvasText 22%, transparent); background: Canvas; color: CanvasText; border-radius: 6px; padding: 6px 10px; }
  </style>
</head>
<body>
  <header>
    <h1>Fieldwork Dashboard</h1>
    <div>
      <button id="refresh" type="button">Refresh</button>
      <span id="generated" class="meta"></span>
    </div>
  </header>
  <main>
    <div id="root" class="grid"></div>
  </main>
  <script>
    const root = document.getElementById("root");
    const generated = document.getElementById("generated");
    const refresh = document.getElementById("refresh");

    function node(tag, className, text) {
      const el = document.createElement(tag);
      if (className) el.className = className;
      if (text !== undefined) el.textContent = text;
      return el;
    }

    function row(label, value) {
      const r = node("div", "row");
      r.append(node("span", "label", label), node("span", "value", value || "-"));
      return r;
    }

    function renderRepo(repo) {
      const card = node("section", "repo");
      card.append(node("h2", "", repo.slug));
      const worktrees = repo.worktrees || {};
      const prs = repo.prs || {};
      const audit = repo.latest_audit_event || {};
      card.append(row("Worktrees", String(Object.keys(worktrees).length)));
      card.append(row("Latest audit", audit.event ? `${audit.event} ${audit.branch || ""}` : "none"));
      card.append(row("Resume context", repo.resume_context_present ? repo.resume_context_path : "missing"));
      for (const [path, wt] of Object.entries(worktrees)) {
        card.append(row(wt.branch || "worktree", `${path} - ${String(wt.rev || "").slice(0, 12)} - dirty ${wt.dirty_count || 0}`));
      }
      if (Object.keys(prs).length) {
        const list = node("ul", "");
        for (const [branch, pr] of Object.entries(prs)) {
          list.append(node("li", "", `${branch} - #${pr.number || "?"} - ${pr.state || "open"} ${pr.url || ""}`));
        }
        card.append(list);
      }
      if (repo.journal_tail && repo.journal_tail.length) {
        const list = node("ul", "");
        for (const line of repo.journal_tail.slice(-5)) list.append(node("li", "", line));
        card.append(list);
      }
      return card;
    }

    async function load() {
      const res = await fetch("/api/status", { cache: "no-store" });
      const data = await res.json();
      generated.textContent = data.generated_at ? `Updated ${data.generated_at}` : "";
      const repos = data.repos || [];
      if (!repos.length) {
        root.replaceChildren(node("div", "empty", "No Fieldwork repo state found yet."));
        return;
      }
      root.replaceChildren(...repos.map(renderRepo));
    }

    refresh.addEventListener("click", load);
    load().catch((err) => root.replaceChildren(node("div", "empty", String(err))));
  </script>
</body>
</html>
"""


def snapshot_json() -> tuple[int, bytes]:
    try:
        result = subprocess.run(
            [SNAPSHOT],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=10,
        )
        json.loads(result.stdout.decode("utf-8"))
        return 200, result.stdout
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired, json.JSONDecodeError):
        return 503, b'{"ok": false, "error": "status snapshot unavailable"}\n'


class DashboardHandler(BaseHTTPRequestHandler):
    server_version = "fieldwork-dashboard/1"

    def send_bytes(self, status: int, content_type: str, body: bytes) -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self) -> None:  # noqa: N802
        if self.path in ("/", "/index.html"):
            self.send_bytes(200, "text/html; charset=utf-8", INDEX_HTML.encode("utf-8"))
            return
        if self.path == "/api/status":
            status, body = snapshot_json()
            self.send_bytes(status, "application/json; charset=utf-8", body)
            return
        if self.path == "/healthz":
            self.send_bytes(200, "application/json; charset=utf-8", b'{"ok": true}\n')
            return
        self.send_bytes(404, "application/json; charset=utf-8", b'{"ok": false, "error": "not found"}\n')

    def method_not_allowed(self) -> None:
        self.send_bytes(405, "application/json; charset=utf-8", b'{"ok": false, "error": "GET only"}\n')

    do_HEAD = method_not_allowed  # type: ignore[assignment]
    do_POST = method_not_allowed  # type: ignore[assignment]
    do_PUT = method_not_allowed  # type: ignore[assignment]
    do_DELETE = method_not_allowed  # type: ignore[assignment]
    do_PATCH = method_not_allowed  # type: ignore[assignment]

    def log_message(self, fmt: str, *args: object) -> None:
        return


def main() -> int:
    if HOST != "127.0.0.1":
        print("fieldwork-dashboard-server binds only to 127.0.0.1", file=sys.stderr)
        return 2
    server = ThreadingHTTPServer((HOST, PORT), DashboardHandler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
