#!/usr/bin/env python3
"""Emit a local Fieldwork status snapshot as JSON.

This helper is intentionally local-only: no SSH, no top-level `fieldwork`
dispatch, and no shell renderers. It reads the agent user's Fieldwork state
artifacts plus the broker audit log when the audit-read ACL allows it.
"""
from __future__ import annotations

from datetime import datetime, timezone
import json
import os
from pathlib import Path


SCHEMA_VERSION = 1


def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def load_json(path: Path) -> dict:
    try:
        with open(path) as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (FileNotFoundError, OSError, json.JSONDecodeError):
        return {}


def tail_lines(path: Path, limit: int) -> list[str]:
    try:
        lines = path.read_text(errors="replace").splitlines()
    except OSError:
        return []
    return lines[-limit:]


def audit_paths(audit_log: Path) -> list[Path]:
    paths = [audit_log]
    try:
        paths.extend(sorted(audit_log.parent.glob(f"{audit_log.name}.[0-9]*")))
    except OSError:
        pass
    return [path for path in paths if path.is_file()]


def latest_audit_by_slug(audit_log: Path) -> dict[str, dict]:
    latest: dict[str, dict] = {}
    for path in audit_paths(audit_log):
        try:
            lines = path.read_text(errors="replace").splitlines()
        except OSError:
            continue
        for line in lines:
            if not line.strip():
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(event, dict):
                continue
            slug = event.get("repo_path_slug")
            if not isinstance(slug, str) or not slug:
                continue
            old = latest.get(slug)
            if old is None or str(event.get("ts") or "") >= str(old.get("ts") or ""):
                latest[slug] = event
    return latest


def repo_slugs(projects_root: Path, events_dir: Path) -> set[str]:
    slugs: set[str] = set()
    try:
        for entry in projects_root.iterdir():
            if entry.is_dir() and (entry / ".git").exists():
                slugs.add(entry.name)
    except OSError:
        pass
    try:
        for entry in events_dir.glob("*.json"):
            slugs.add(entry.stem)
    except OSError:
        pass
    return slugs


def snapshot() -> dict:
    home = Path(os.environ.get("HOME", "")).expanduser()
    projects_root = Path(os.environ.get("FIELDWORK_PROJECTS_ROOT", home / "projects"))
    state_root = Path(os.environ.get("FIELDWORK_EVENT_STATE_DIR", home / ".fieldwork/state"))
    events_dir = state_root / "events"
    resume_dir = state_root / "resume-context"
    journal_dir = Path(os.environ.get("FIELDWORK_JOURNAL_DIR", home / ".fieldwork/project-journals"))
    audit_log = Path(os.environ.get("FIELDWORK_BROKER_AUDIT_LOG_PATH", "/var/lib/fieldwork-pr-broker/audit.jsonl"))

    audit_latest = latest_audit_by_slug(audit_log)
    repos = []
    for slug in sorted(repo_slugs(projects_root, events_dir) | set(audit_latest.keys())):
        state_path = events_dir / f"{slug}.json"
        state = load_json(state_path)
        worktrees = state.get("worktrees") if isinstance(state.get("worktrees"), dict) else {}
        prs = state.get("prs") if isinstance(state.get("prs"), dict) else {}
        resume_path = resume_dir / f"{slug}.md"
        journal_path = journal_dir / f"{slug}.md"
        repos.append({
            "slug": slug,
            "repo_path": str(projects_root / slug),
            "state_path": str(state_path),
            "state_present": state_path.is_file(),
            "resume_context_path": str(resume_path),
            "resume_context_present": resume_path.is_file(),
            "journal_path": str(journal_path),
            "journal_tail": tail_lines(journal_path, 10),
            "worktrees": worktrees,
            "prs": prs,
            "last_throttled_checks": state.get("last_throttled_checks") if isinstance(state.get("last_throttled_checks"), dict) else {},
            "latest_audit_event": audit_latest.get(slug),
        })

    return {
        "schema_version": SCHEMA_VERSION,
        "generated_at": utc_now(),
        "projects_root": str(projects_root),
        "state_root": str(state_root),
        "audit_log_path": str(audit_log),
        "audit_readable": audit_log.is_file() and os.access(audit_log, os.R_OK),
        "repos": repos,
    }


def main() -> int:
    print(json.dumps(snapshot(), sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
