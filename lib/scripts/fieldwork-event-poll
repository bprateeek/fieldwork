#!/usr/bin/env bash
# fieldwork-event-poll - local event/artifact poller for Fieldwork repos.
#
# Runs as the agent user from a systemd user timer. It reads canonical repos
# under FIELDWORK_PROJECTS_ROOT, discovers linked worktrees via
# `git worktree list --porcelain`, writes ~/.fieldwork/state artifacts, appends
# git-derived journal entries, and drops versioned notification envelopes.

set -euo pipefail

python3 - <<'PY'
from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path


SCHEMA_VERSION = 1
BASE_BRANCH_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._/-]{0,99}$")
SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]{0,30}$")

home = Path(os.environ.get("HOME", "")).expanduser()
projects_root = Path(os.environ.get("FIELDWORK_PROJECTS_ROOT", home / "projects"))
state_root = Path(os.environ.get("FIELDWORK_EVENT_STATE_DIR", home / ".fieldwork/state"))
events_dir = state_root / "events"
resume_dir = state_root / "resume-context"
journal_dir = Path(os.environ.get("FIELDWORK_JOURNAL_DIR", home / ".fieldwork/project-journals"))
audit_log_path = Path(os.environ.get("FIELDWORK_BROKER_AUDIT_LOG_PATH", "/var/lib/fieldwork-pr-broker/audit.jsonl"))
notifications_dir = Path(os.environ.get("FIELDWORK_NOTIFICATIONS_DIR", "/var/lib/fieldwork-pr-broker/notifications"))
pr_refresh_seconds = int(os.environ.get("FIELDWORK_EVENT_POLL_PR_REFRESH_SECONDS", "300"))
merge_refresh_seconds = int(os.environ.get("FIELDWORK_EVENT_POLL_MERGE_REFRESH_SECONDS", "300"))


def utc_now() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_iso(value: object) -> float:
    if not isinstance(value, str) or not value:
        return 0.0
    try:
        return datetime.strptime(value, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc).timestamp()
    except ValueError:
        return 0.0


def run(argv: list[str], cwd: Path | None = None, timeout: int = 15) -> str | None:
    try:
        out = subprocess.run(
            argv,
            cwd=str(cwd) if cwd else None,
            check=True,
            timeout=timeout,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        return out.stdout
    except (OSError, subprocess.CalledProcessError, subprocess.TimeoutExpired):
        return None


def count_lines(text: str | None) -> int:
    if not text:
        return 0
    return len([line for line in text.splitlines() if line.strip()])


def load_json(path: Path) -> dict:
    try:
        with open(path) as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (FileNotFoundError, OSError, json.JSONDecodeError):
        return {}


def write_json_atomic(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp-{os.getpid()}-{uuid.uuid4().hex}")
    with open(tmp, "w") as f:
        json.dump(data, f, sort_keys=True, indent=2)
        f.write("\n")
    os.replace(tmp, path)


def write_text_atomic(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp-{os.getpid()}-{uuid.uuid4().hex}")
    with open(tmp, "w") as f:
        f.write(text)
    os.replace(tmp, path)


def append_journal(slug: str, branch: str, subject: str) -> None:
    journal_dir.mkdir(parents=True, exist_ok=True)
    line = f"- {utc_now()} | {branch or '-'} | {subject or '(no commits)'}\n"
    with open(journal_dir / f"{slug}.md", "a") as f:
        f.write(line)


def audit_paths() -> list[Path]:
    parent = audit_log_path.parent
    paths = [audit_log_path]
    try:
        paths.extend(sorted(parent.glob(f"{audit_log_path.name}.[0-9]*")))
    except OSError:
        pass
    return [path for path in paths if path.is_file()]


def audit_events_for(slug: str) -> list[dict]:
    events: list[dict] = []
    for path in audit_paths():
        try:
            lines = path.read_text().splitlines()
        except OSError:
            continue
        for line in lines:
            if not line.strip():
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(event, dict) and event.get("repo_path_slug") == slug:
                events.append(event)
    events.sort(key=lambda item: str(item.get("ts") or ""))
    return events


def audit_base_branch(slug: str) -> str | None:
    for event in reversed(audit_events_for(slug)):
        base = event.get("base_branch")
        if isinstance(base, str) and BASE_BRANCH_RE.match(base):
            return base
    return None


def seed_prs_from_audit(slug: str, state: dict) -> None:
    prs = state.setdefault("prs", {})
    if not isinstance(prs, dict):
        prs = {}
        state["prs"] = prs
    for event in audit_events_for(slug):
        if event.get("event") != "pr_opened":
            continue
        branch = event.get("branch")
        pr_url = event.get("pr_url")
        if not isinstance(branch, str) or not isinstance(pr_url, str):
            continue
        match = re.search(r"/pull/([0-9]+)(?:$|[/?#])", pr_url)
        if not match:
            continue
        record = prs.get(branch)
        if not isinstance(record, dict):
            record = {}
        record.update({
            "number": int(match.group(1)),
            "url": pr_url,
            "base_branch": event.get("base_branch") if isinstance(event.get("base_branch"), str) else record.get("base_branch"),
            "repo": event.get("repo") if isinstance(event.get("repo"), str) else record.get("repo"),
        })
        record.setdefault("last_checked", "")
        prs[branch] = record


def origin_head(repo: Path) -> str:
    out = run(["git", "symbolic-ref", "--short", "refs/remotes/origin/HEAD"], cwd=repo)
    if out:
        value = out.strip()
        if value.startswith("origin/") and BASE_BRANCH_RE.match(value[len("origin/"):]):
            return value[len("origin/"):]
    return "main"


def resolve_base_branch(slug: str, canonical: Path) -> str:
    default_file = canonical / ".fieldwork/default-branch"
    try:
        value = default_file.read_text().strip()
        if BASE_BRANCH_RE.match(value):
            return value
    except OSError:
        pass
    return audit_base_branch(slug) or origin_head(canonical)


def parse_worktrees(canonical: Path) -> list[dict]:
    out = run(["git", "worktree", "list", "--porcelain"], cwd=canonical)
    if not out:
        return []
    entries: list[dict] = []
    current: dict = {}
    for line in out.splitlines():
        if line.startswith("worktree "):
            if current:
                entries.append(current)
            current = {"path": line[len("worktree "):]}
        elif line.startswith("HEAD "):
            current["head"] = line[len("HEAD "):]
        elif line.startswith("branch "):
            ref = line[len("branch "):]
            current["branch"] = ref[len("refs/heads/"):] if ref.startswith("refs/heads/") else ref
        elif not line.strip() and current:
            entries.append(current)
            current = {}
    if current:
        entries.append(current)
    return entries


def ref_exists(repo: Path, ref: str) -> bool:
    return run(["git", "show-ref", "--verify", "--quiet", ref], cwd=repo) is not None


def ahead_count(repo: Path, base_branch: str) -> int:
    candidates = [f"refs/remotes/origin/{base_branch}", f"refs/heads/{base_branch}"]
    for ref in candidates:
        if not ref_exists(repo, ref):
            continue
        out = run(["git", "rev-list", "--count", "HEAD", f"^{ref}"], cwd=repo)
        if out and out.strip().isdigit():
            return int(out.strip())
    return 0


def worktree_fingerprint(path: Path, branch_hint: str | None, base_branch: str) -> dict | None:
    rev = run(["git", "rev-parse", "HEAD"], cwd=path)
    if not rev:
        return None
    branch = branch_hint or (run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=path) or "").strip()
    subject = (run(["git", "log", "-1", "--pretty=%s"], cwd=path) or "").strip()
    return {
        "branch": branch or "HEAD",
        "rev": rev.strip(),
        "base_branch": base_branch,
        "ahead_of_base": ahead_count(path, base_branch),
        "staged_count": count_lines(run(["git", "diff", "--cached", "--name-only"], cwd=path)),
        "dirty_count": count_lines(run(["git", "diff", "--name-only"], cwd=path)),
        "untracked_count": count_lines(run(["git", "ls-files", "--others", "--exclude-standard"], cwd=path)),
        "latest_commit_subject": subject,
        "last_seen": utc_now(),
    }


def comparable_fingerprint(record: dict) -> dict:
    keys = [
        "branch",
        "rev",
        "base_branch",
        "ahead_of_base",
        "staged_count",
        "dirty_count",
        "untracked_count",
    ]
    return {key: record.get(key) for key in keys}


def drop_notification(payload: dict) -> None:
    tmp: Path | None = None
    try:
        notifications_dir.mkdir(parents=True, exist_ok=True)
        uid = uuid.uuid4().hex
        tmp = notifications_dir / f".tmp-{uid}"
        final = notifications_dir / f"{uid}.json"
        with open(tmp, "w") as f:
            json.dump(payload, f, sort_keys=True)
            f.write("\n")
        try:
            os.chmod(tmp, 0o660)
        except OSError:
            pass
        os.replace(tmp, final)
    except OSError:
        if tmp is not None:
            try:
                tmp.unlink()
            except OSError:
                pass


def notify_git_state(slug: str, path: str, fp: dict) -> None:
    short_rev = str(fp.get("rev") or "")[:12]
    branch = str(fp.get("branch") or "-")
    text = (
        f"{slug} @ {branch} updated: {short_rev} "
        f"ahead={fp.get('ahead_of_base', 0)} staged={fp.get('staged_count', 0)} "
        f"dirty={fp.get('dirty_count', 0)} untracked={fp.get('untracked_count', 0)}"
    )
    drop_notification({
        "schema": 1,
        "kind": "repo_state",
        "source": "event_poller",
        "event": "git_state_changed",
        "repo_slug": slug,
        "request_id": None,
        "branch": branch,
        "dedupe_key": f"git_state_changed:{slug}:{path}:{branch}:{fp.get('rev')}:{fp.get('staged_count')}:{fp.get('dirty_count')}:{fp.get('untracked_count')}",
        "text": text,
    })


def notify_pr_merged(slug: str, branch: str, pr: dict) -> None:
    number = pr.get("number")
    url = pr.get("url") or ""
    text = f"{slug} PR #{number} merged"
    if url:
        text = f"{text}: {url}"
    drop_notification({
        "schema": 1,
        "kind": "repo_state",
        "source": "event_poller",
        "event": "pr_merged",
        "repo_slug": slug,
        "request_id": None,
        "branch": branch,
        "dedupe_key": f"pr_merged:{slug}:{branch}:{number}:{pr.get('merged_at')}",
        "text": text,
    })


def open_pr_lines(repo: Path, state: dict, changed: bool) -> list[str]:
    cache = state.get("open_prs")
    throttles = state.setdefault("last_throttled_checks", {})
    if not isinstance(throttles, dict):
        throttles = {}
        state["last_throttled_checks"] = throttles
    now = time.time()
    if (
        not changed
        and isinstance(cache, dict)
        and now - parse_iso(cache.get("last_checked")) < pr_refresh_seconds
        and isinstance(cache.get("lines"), list)
    ):
        return [str(line) for line in cache["lines"]]
    if shutil.which("gh") is None:
        lines = ["(gh not installed)"]
    else:
        out = run(["gh", "pr", "list", "--limit", "5", "--json", "number,title,headRefName,statusCheckRollup"], cwd=repo, timeout=20)
        if not out:
            lines = ["(gh not authenticated or repo lookup failed)"]
        else:
            try:
                rows = json.loads(out)
            except json.JSONDecodeError:
                rows = []
            if isinstance(rows, list) and rows:
                lines = [
                    f"#{row.get('number')} {row.get('title')} [{row.get('headRefName')}]"
                    for row in rows
                    if isinstance(row, dict)
                ] or ["(no open PRs)"]
            else:
                lines = ["(no open PRs)"]
    checked_at = utc_now()
    state["open_prs"] = {"last_checked": checked_at, "lines": lines}
    throttles["open_prs"] = checked_at
    return lines


def head_lines(path: Path, limit: int) -> list[str]:
    try:
        return path.read_text(errors="replace").splitlines()[:limit]
    except OSError:
        return []


def tail_lines(path: Path, limit: int) -> list[str]:
    try:
        lines = path.read_text(errors="replace").splitlines()
    except OSError:
        return []
    return lines[-limit:]


def render_resume(slug: str, repo: Path, state: dict, changed: bool) -> None:
    lines: list[str] = [f"## Resume context for {slug}", ""]
    lines.extend(["### Repo guidance"])
    lines.extend(head_lines(repo / "CLAUDE.md", 80))
    lines.extend(["", "### Review checklist"])
    lines.extend(head_lines(repo / "REVIEW.md", 40))
    lines.extend(["", "### Last 5 commits"])
    log_lines = (run(["git", "log", "-5", "--oneline"], cwd=repo) or "").splitlines()
    lines.extend(log_lines or ["(no git history)"])
    lines.extend(["", "### Open PRs"])
    lines.extend(open_pr_lines(repo, state, changed))
    lines.extend(["", "### Last 10 journal entries"])
    journal_lines = tail_lines(journal_dir / f"{slug}.md", 10)
    if journal_lines:
        lines.extend(journal_lines)
    else:
        lines.append(f"(no journal yet at {journal_dir / f'{slug}.md'})")
    lines.append("")
    write_text_atomic(resume_dir / f"{slug}.md", "\n".join(lines))


def check_pr_merges(slug: str, canonical: Path, state: dict) -> bool:
    if shutil.which("gh") is None:
        return False
    prs = state.get("prs")
    if not isinstance(prs, dict):
        return False
    changed = False
    now_iso = utc_now()
    now_ts = time.time()
    for branch, pr in list(prs.items()):
        if not isinstance(pr, dict) or pr.get("merged_at"):
            continue
        number = pr.get("number")
        if not isinstance(number, int):
            continue
        if now_ts - parse_iso(pr.get("last_checked")) < merge_refresh_seconds:
            continue
        pr["last_checked"] = now_iso
        throttles = state.setdefault("last_throttled_checks", {})
        if isinstance(throttles, dict):
            throttles[f"{branch}:pr_state"] = now_iso
        out = run(["gh", "pr", "view", str(number), "--json", "state,mergedAt"], cwd=canonical, timeout=20)
        if not out:
            changed = True
            continue
        try:
            payload = json.loads(out)
        except json.JSONDecodeError:
            payload = {}
        merged_at = payload.get("mergedAt") if isinstance(payload, dict) else None
        state_value = payload.get("state") if isinstance(payload, dict) else None
        if isinstance(merged_at, str) and merged_at:
            pr["state"] = state_value or "MERGED"
            pr["merged_at"] = merged_at
            changed = True
            notify_pr_merged(slug, str(branch), pr)
        elif isinstance(state_value, str):
            pr["state"] = state_value
            changed = True
    return changed


def process_repo(canonical: Path) -> None:
    slug = canonical.name
    if not SLUG_RE.match(slug) or not (canonical / ".git").exists():
        return
    state_path = events_dir / f"{slug}.json"
    state = load_json(state_path)
    if state.get("schema_version") != SCHEMA_VERSION:
        state = {"schema_version": SCHEMA_VERSION, "repo_slug": slug}
    state["schema_version"] = SCHEMA_VERSION
    state["repo_slug"] = slug
    seed_prs_from_audit(slug, state)
    base_branch = resolve_base_branch(slug, canonical)
    previous_worktrees = state.get("worktrees")
    if not isinstance(previous_worktrees, dict):
        previous_worktrees = {}
    next_worktrees: dict[str, dict] = {}
    changed = False
    resume_source = canonical

    for entry in parse_worktrees(canonical):
        path_value = entry.get("path")
        if not isinstance(path_value, str):
            continue
        path = Path(path_value)
        fp = worktree_fingerprint(path, entry.get("branch") if isinstance(entry.get("branch"), str) else None, base_branch)
        if fp is None:
            continue
        key = str(path)
        next_worktrees[key] = fp
        old = previous_worktrees.get(key) if isinstance(previous_worktrees.get(key), dict) else {}
        if comparable_fingerprint(old) != comparable_fingerprint(fp):
            changed = True
            resume_source = path
            append_journal(slug, str(fp.get("branch") or "-"), str(fp.get("latest_commit_subject") or ""))
            notify_git_state(slug, key, fp)

    if set(previous_worktrees.keys()) != set(next_worktrees.keys()):
        changed = True
    state["worktrees"] = next_worktrees
    if check_pr_merges(slug, canonical, state):
        changed = True
    if changed or not (resume_dir / f"{slug}.md").is_file():
        render_resume(slug, resume_source, state, changed)
    write_json_atomic(state_path, state)


def main() -> int:
    events_dir.mkdir(parents=True, exist_ok=True)
    resume_dir.mkdir(parents=True, exist_ok=True)
    journal_dir.mkdir(parents=True, exist_ok=True)
    if not projects_root.is_dir():
        return 0
    for entry in sorted(projects_root.iterdir()):
        if entry.is_dir():
            process_repo(entry)
    return 0


raise SystemExit(main())
PY
