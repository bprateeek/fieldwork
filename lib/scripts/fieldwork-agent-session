#!/usr/bin/env bash
# fieldwork-agent-session — systemd-invoked launcher for one per-repo agent
# session. It selects an agent adapter and execs it.
#
# Usage: fieldwork-agent-session <repo-slug>
#
# Invoked by the fieldwork-agent@<slug>.service systemd unit. This wrapper is
# the seam that lets Fieldwork run agents other than Claude Code without
# touching the systemd unit, onboarding, or the broker: only the adapter
# changes. The adapter is chosen by FIELDWORK_AGENT_ADAPTER (default
# claude-remote-control) and resolved from ~/.fieldwork/infra/agents/<name>.

set -euo pipefail

slug="${1:-}"
[ -n "$slug" ] || { echo "usage: fieldwork-agent-session <repo-slug>" >&2; exit 2; }

# Allowlist regex: lowercase alphanum + hyphens, 1–31 chars (matches the broker
# and onboarding slug contract).
[[ "$slug" =~ ^[a-z0-9][a-z0-9-]{0,30}$ ]] || {
  echo "[fieldwork-agent-session] invalid repo slug: $slug" >&2
  echo "[fieldwork-agent-session] must match ^[a-z0-9][a-z0-9-]{0,30}\$" >&2
  exit 2
}

repo_dir="$HOME/projects/$slug"
[ -d "$repo_dir/.git" ] || {
  echo "[fieldwork-agent-session] no git repo at $repo_dir" >&2
  exit 1
}

profile="default"
if [ -f "$repo_dir/.fieldwork/profile" ]; then
  profile="$(head -1 "$repo_dir/.fieldwork/profile" 2>/dev/null | tr -d '[:space:]' || true)"
  [ -n "$profile" ] || profile="default"
fi
export FIELDWORK_PROFILE="$profile"

# Branch prefix the agent commits under; the broker enforces the same prefix.
export FIELDWORK_BRANCH_PREFIX="${FIELDWORK_BRANCH_PREFIX:-fieldwork}"

FIELDWORK_AGENT_CAPACITY_DEFAULT=2
FIELDWORK_AGENT_CAPACITY_MAX=4

fieldwork_agent_capacity_from_file() {
  local config="$HOME/.fieldwork/agent.conf"
  [ -f "$config" ] || return 1
  awk '
    /^[[:space:]]*($|#)/ { next }
    /^[[:space:]]*capacity[[:space:]]*=/ {
      sub(/^[^=]*=/, "")
      gsub(/^[[:space:]]+|[[:space:]]+$/, "")
      print
      exit
    }
  ' "$config"
}

fieldwork_agent_capacity_normalize() {
  local raw="${1:-}"
  local default="$FIELDWORK_AGENT_CAPACITY_DEFAULT"
  local max="${FIELDWORK_AGENT_CAPACITY_MAX:-4}"
  case "$max" in ''|*[!0-9]*) max=4 ;; esac
  [ "$max" -ge 1 ] 2>/dev/null || max=4
  case "$raw" in
    '') printf '%s\n' "$default"; return 0 ;;
    *[!0-9]*)
      echo "[fieldwork-agent-session] invalid capacity '$raw'; using $default" >&2
      printf '%s\n' "$default"
      return 0
      ;;
  esac
  if [ "$raw" -lt 1 ] 2>/dev/null; then
    printf '1\n'
  elif [ "$raw" -gt "$max" ] 2>/dev/null; then
    echo "[fieldwork-agent-session] capacity $raw exceeds max $max; using $max" >&2
    printf '%s\n' "$max"
  else
    printf '%s\n' "$raw"
  fi
}

capacity_raw="${FIELDWORK_AGENT_CAPACITY:-}"
if [ -z "$capacity_raw" ]; then
  capacity_raw="$(fieldwork_agent_capacity_from_file 2>/dev/null || true)"
fi
FIELDWORK_AGENT_CAPACITY="$(fieldwork_agent_capacity_normalize "$capacity_raw")"
export FIELDWORK_AGENT_CAPACITY

# While the checkout sits on the onboarding init branch the init PR has not
# been merged: serving sessions here would dirty the main checkout and base
# PRs on the init branch. Exit 0 so Restart=on-failure does not crash-loop;
# `fieldwork refresh` returns the checkout to the default branch and restarts
# this unit, which lifts the gate.
init_branch="$FIELDWORK_BRANCH_PREFIX/init"
current_branch="$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
if [ "$current_branch" = "$init_branch" ]; then
  echo "[fieldwork-agent-session] $slug checkout is on $init_branch (init PR not merged)" >&2
  echo "[fieldwork-agent-session] refusing to serve sessions from the init branch" >&2
  echo "[fieldwork-agent-session] merge the init PR, then run: fieldwork refresh $slug" >&2
  exit 0
fi

adapter_name="${FIELDWORK_AGENT_ADAPTER:-claude-remote-control}"
case "$adapter_name" in
  */*|*..*|"")
    echo "[fieldwork-agent-session] invalid adapter name: $adapter_name" >&2
    exit 2
    ;;
esac
adapter="$HOME/.fieldwork/infra/agents/$adapter_name"
[ -x "$adapter" ] || {
  echo "[fieldwork-agent-session] agent adapter not found or not executable: $adapter" >&2
  echo "[fieldwork-agent-session] available adapters:" >&2
  ls -1 "$HOME/.fieldwork/infra/agents" 2>/dev/null | sed 's/^/  /' >&2 || true
  exit 1
}

# Adapters declare a process model via a `# fieldwork-process-model: <model>`
# header. This per-repo session unit only runs remote_control_daemon adapters
# (a long-running session). one_shot_job agents (e.g. aider) are driven by
# fieldwork-task-dispatcher, not here; desktop_relay agents have no unit.
# Unset/unknown defaults to remote_control_daemon so existing adapters are
# unaffected.
fieldwork_agent_process_model() {
  local file="$1" model
  model="$(awk '
    /^[[:space:]]*#[[:space:]]*fieldwork-process-model[[:space:]]*:/ {
      sub(/^[^:]*:/, ""); gsub(/[[:space:]]/, ""); print; exit
    }
  ' "$file" 2>/dev/null)"
  printf '%s\n' "${model:-remote_control_daemon}"
}

process_model="$(fieldwork_agent_process_model "$adapter")"
case "$process_model" in
  remote_control_daemon)
    exec "$adapter" "$slug" "$repo_dir"
    ;;
  one_shot_job)
    echo "[fieldwork-agent-session] adapter '$adapter_name' is a one_shot_job agent" >&2
    echo "[fieldwork-agent-session] it is driven by fieldwork-task-dispatcher, not a per-repo session" >&2
    echo "[fieldwork-agent-session] submit work with: fieldwork task add $slug \"<prompt>\"" >&2
    exit 0
    ;;
  desktop_relay)
    echo "[fieldwork-agent-session] adapter '$adapter_name' is a desktop_relay agent (no session unit)" >&2
    exit 0
    ;;
  *)
    echo "[fieldwork-agent-session] adapter '$adapter_name' declares unknown process model: $process_model" >&2
    exit 2
    ;;
esac
